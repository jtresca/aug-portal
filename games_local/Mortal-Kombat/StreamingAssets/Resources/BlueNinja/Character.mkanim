    "rules": [ 
        "GO IceBlast WHEN ICEBLAST and GROUNDED and !B\u2014 and 2IN1 and !NOICEBLAST and !NOSPECIALS and !P2.NOICEJUGGLE", 
        "GO Slide WHEN LEFT and LP and B and LK and 2IN1 and TIMER1>120 and !NOSPECIALS", 
        "GO Slide WHEN LEFT and LP and B\u2014 and LK\u2014 and 2IN1 and TIMER1>120 and !NOSPECIALS", 
        "GO Slide WHEN LEFT and LK and B\u2014 and LP\u2014 and 2IN1 and TIMER1>120 and !NOSPECIALS", 
