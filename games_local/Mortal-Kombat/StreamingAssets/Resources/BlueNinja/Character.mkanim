        "SET BLOCKING WHEN HITSTATE and B\u2014 and !P2.HIT and GROUNDED", 
        "SET CROUCHING WHEN HGUARD and DOWN and B\u2014", 
        "CLR CROUCHING WHEN HGUARD and !DOWN and CROUCHING", 
        "SET STANDING WHEN LGUARD and !DOWN and !STANDING", 
        "CLR STANDING WHEN LGUARD and DOWN and STANDING", 
        "SET DESCENDING WHEN Y>9", 
        "CLR DESCENDING WHEN Y=0"
