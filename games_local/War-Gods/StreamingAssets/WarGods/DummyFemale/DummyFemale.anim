    ]
    }, 
{
    "name": "Conditions_Command",
    "frames": [ 
        
    ],
    "followWith": "",
    "rules": [ 
        "GO Light_Combo_Part_1 WHEN LIGHT", 
        "GO Heavy_Attack_Charge WHEN INPUTS(HEAVY)", 
        "DORULES Conditions_Special WHEN SPECIAL"
    ]
    }, 
{
    "name": "Conditions_Idle",
    "frames": [ 
        
    ],
    "followWith": "",
    "rules": [ 
        "\/\/GO Win WHEN WON", 
        "GO Match_End_Fall _Over WHEN LOST", 
        "CLR LIGHTCOUNT MEDIUMCOUNT HEAVYCOUNT WHEN P2.FREE and LIGHTCOUNT>0", 
        "CLR LIGHTCOUNT MEDIUMCOUNT HEAVYCOUNT WHEN P2.FREE and MEDIUMCOUNT>0", 
        "CLR LIGHTCOUNT MEDIUMCOUNT HEAVYCOUNT WHEN P2.FREE and HEAVYCOUNT>0", 
        "SETCOMBO PARRY_COMBO WHEN BLOCK and !BLOCKING and !PARRY and !CHAIN", 
        "GO Block_Start WHEN COMBO(PARRY_COMBO) and !CHAIN", 
        "GO Block_Start WHEN BLOCK\u2014 and !BLOCKING and !CHAIN", 
        "GO Block_Loop WHEN BLOCK\u2014 and BLOCKING and !CHAIN", 
        "GO Dash_Forward WHEN FWD", 
        "GO Dash_Backward WHEN BACK", 
        "DORULES Conditions_Command WHEN FRAME>-1"
    ]
    }, 
