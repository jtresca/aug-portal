    "rules": [ 
        "SETVEL 0, WHEN FRAME=12", 
        "DORULES Conditions_Idle WHEN FREE", 
        "GO Light_Combo_Part_1 WHEN INPUTS(LIGHT) and CHAIN and !FREE and LIGHTCOUNT=0", 
        "GO Light_Combo_Part_2 WHEN INPUTS(LIGHT) and CHAIN and !FREE and LIGHTCOUNT=1", 
        "GO Light_Combo_Part_3 WHEN INPUTS(LIGHT) and CHAIN and !FREE and LIGHTCOUNT=2", 
        "GO Light_Combo_Part_4 WHEN INPUTS(LIGHT) and CHAIN and !FREE and LIGHTCOUNT=3", 
        "GO Medium_Combo_Part_2 WHEN INPUTS(FWD) and CHAIN and !FREE", 
        "GO Heavy_Attack_Charge WHEN INPUTS(HEAVY) and CHAIN and !FREE", 
        "DORULES Conditions_Special WHEN INPUTS(SPECIAL) and CHAIN"
    ]
